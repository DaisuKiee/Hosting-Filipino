{
  "name": "discord-bot-panel",
  "version": "1.0.0",
  "description": "Self-hosted Discord bot management panel",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "install-all": "npm install && cd client && npm install"
  },
  "keywords": ["discord", "bot", "panel", "hosting"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "dockerode": "^4.0.0",
    "socket.io": "^4.6.0",
    "multer": "^1.4.5-lts.1",
    "express-validator": "^7.0.1",
    "pm2": "^5.3.0",
    "adm-zip": "^0.5.10",
    "tar": "^6.2.0",
    "node-7z": "^3.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2"
  }
}
